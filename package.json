{
  "name": "shadowkey",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json",
    "compile": "npx hardhat compile",
    "test:contract": "npx hardhat test",
    "deploy:sepolia": "npx hardhat run scripts/deploy.cjs --network baseSepolia",
    "deploy:mainnet": "npx hardhat run scripts/deploy.cjs --network baseMainnet",
    "deploy:status": "npx hardhat run scripts/deployAttestation.cjs --network statusNetworkSepolia",
    "deploy:slice-gate": "npx hardhat run scripts/deploySliceGate.cjs --network baseSepolia",
    "gasless:demo": "node scripts/gaslessAttest.cjs",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "ethers": "^6.13.0",
    "i18next": "^25.8.18",
    "lucide-react": "^0.344.0",
    "qrcode.react": "^4.2.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^16.5.8",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "^1.1.2",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "chai": "^4.5.0",
    "dotenv": "^17.3.1",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "hardhat": "^2.28.6",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2",
    "vitest": "^4.1.0"
  }
}
