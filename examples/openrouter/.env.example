# AI Model Selection (Default: nvidia/nemotron-nano-9b-v2:free)
# Options:
#   - nvidia/nemotron-nano-9b-v2:free (Fast, structured output)
#   - meta-llama/llama-3.3-70b-instruct:free (Quality + speed balance)
#   - google/gemini-2.0-flash-exp:free (General purpose)
#   - arcee-ai/trinity-large-preview:free (Complex reasoning)
# Note: All models have automatic failover enabled
AI_MODEL=nvidia/nemotron-nano-9b-v2:free
