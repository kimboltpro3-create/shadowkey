# === Supabase (already needed for the app) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# === Smart Contract Deployment (Hardhat) ===
DEPLOYER_PRIVATE_KEY=your-metamask-private-key-without-0x-prefix
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# === Frontend Contract Integration (set AFTER deploying) ===
VITE_SHADOW_VAULT_ADDRESS=0x_your_deployed_contract_address
VITE_CHAIN_ID=84532

# === IPFS Disclosure Anchoring (optional — additive) ===
# Free JWT from https://app.pinata.cloud (2 GB free, no credit card required)
# When set, each approved disclosure is pinned to IPFS/Filecoin for independent verification
VITE_PINATA_JWT=your-pinata-jwt-token
